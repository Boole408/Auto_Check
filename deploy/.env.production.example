# Core server binding. The installer keeps these fixed for single-host deployments.
NODE_ENV=production
HOST=127.0.0.1
PORT=3000

# Public origin used by the browser and login cookie flow.
CORS_ORIGIN=https://example.com

# Login credentials for the built-in admin page.
APP_LOGIN_USERNAME=admin
APP_LOGIN_PASSWORD=change-this-login-password
APP_LOGIN_SESSION_SECRET=change-this-session-secret

# Upstream target site and local account file location.
CAOWO_BASE_URL=https://caowo.xin
CAOWO_ACCOUNTS_FILE=/opt/auto-cw/data/accounts.txt

# Runtime behavior.
CAOWO_CACHE_TTL_MS=10000
CAOWO_RATE_LIMIT_COOLDOWN_MS=180000
CAOWO_USAGE_SYNC_DELAY_MS=4000
CAOWO_TIMEOUT_MS=15000

# Automatic check-in schedule.
CAOWO_AUTO_CHECKIN_ENABLED=1
CAOWO_AUTO_CHECKIN_TIME=00:01
CAOWO_AUTO_CHECKIN_TZ=Asia/Shanghai
CAOWO_AUTO_CHECKIN_CATCH_UP=1
CAOWO_AUTO_CHECKIN_RETRY_MINUTES=10
CAOWO_DEBUG=0
